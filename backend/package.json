{
  "name": "studyhub-backend",
  "version": "1.0.0",
  "description": "StudyHub API - Group Study Management System",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "dev": "nodemon server.js",
    "start": "nodemon server.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:seed": "node prisma/seed.js",
    "db:studio": "prisma studio",
    "lint": "eslint src --ext .js",
    "format": "prettier --write \"src/**/*.js\" \"prisma/**/*.js\"",
    "test": "vitest run --config automation-tests/vitest.config.js",
    "test:watch": "vitest --config automation-tests/vitest.config.js",
    "test:all": "npm run test && npm run test:jest",
    "test:jest": "npm run test:service && npm run test:api && npm run test:e2e",
    "test:service": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --config automation-tests/jest.config.js --testPathPatterns=service.test",
    "test:api": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --config automation-tests/jest.config.js --testPathPatterns=controller.test",
    "test:e2e": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --config automation-tests/jest.config.js --testPathPatterns=e2e.test",
    "test:cov": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --config automation-tests/jest.config.js --coverage",
    "test:cov:vitest": "vitest run --config automation-tests/vitest.config.js --coverage"
  },
  "dependencies": {
    "@prisma/client": "^6.8.2",
    "bcrypt": "^5.1.1",
    "cloudinary": "^2.10.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^4.21.2",
    "express-validator": "^7.2.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "livekit-server-sdk": "^2.15.4",
    "morgan": "^1.10.0"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "eslint": "^9.28.0",
    "jest": "^30.4.2",
    "jest-mock-extended": "^4.0.1",
    "nodemon": "^3.1.14",
    "prettier": "^3.5.3",
    "prisma": "^6.8.2",
    "supertest": "^7.2.2",
    "vitest": "^4.1.7"
  }
}
